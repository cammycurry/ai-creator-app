generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Users ───────────────────────────────────────────

model User {
  id       String  @id @default(cuid())
  clerkId  String  @unique
  email    String  @unique
  name     String?
  imageUrl String?

  // Subscription
  plan                 Plan   @default(FREE)
  stripeCustomerId     String? @unique
  stripeSubscriptionId String? @unique
  planCredits          Int    @default(10)
  packCredits          Int    @default(0)

  // Relations
  creators           Creator[]
  creditTransactions CreditTransaction[]
  contentSets        ContentSet[]
  references         Reference[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Plan {
  FREE
  STARTER
  PRO
  UNLIMITED
}

// ─── Creators ────────────────────────────────────────

model Creator {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name      String
  niche     String[]
  isPreMade Boolean @default(false)
  preMadeId String?

  // Base images
  baseImageUrl         String?
  baseImageUpscaledUrl String?

  // All wizard inputs stored as JSON
  settings Json @default("{}")

  // Reference images for consistency
  referenceImages Json @default("[]")

  // Dense identity paragraph for consistent generation
  promptSeed    String?

  // Voice
  voiceId       String?
  voiceProvider String?

  // Stats
  contentCount Int       @default(0)
  lastUsedAt   DateTime?

  // Relations
  content     Content[]
  contentSets ContentSet[]
  references  Reference[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// ─── Content ─────────────────────────────────────────

model Content {
  id        String @id @default(cuid())
  creatorId String
  creator   Creator @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  type   ContentType
  status ContentStatus @default(GENERATING)

  // Output
  url          String?
  thumbnailUrl String?
  outputs      Json @default("[]")

  // How it was made
  source     ContentSource
  templateId String?
  prompt     String?
  userInput  String?

  // Generation details
  generationSettings Json    @default("{}")
  modelUsed          String?
  creditsCost        Int     @default(0)

  // Ref recipe
  refAttachments  Json?     // Array of ref usage records: [{refId, mode, what, description, ...}]

  // Metadata
  caption String?
  tags    String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contentSetId String?
  contentSet   ContentSet? @relation(fields: [contentSetId], references: [id], onDelete: Cascade)
  slideIndex   Int?
  slideContext  Json?

  @@index([creatorId])
  @@index([creatorId, type])
}

model ContentSet {
  id        String   @id @default(cuid())
  creatorId String
  creator   Creator  @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String
  formatId  String?
  caption   String?
  hashtags  String[]
  slideCount Int     @default(0)
  status    String   @default("GENERATING")
  creditsCost Int    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  contents  Content[]

  @@index([creatorId])
  @@index([userId])
}

enum ContentType {
  IMAGE
  VIDEO
  TALKING_HEAD
}

enum ContentStatus {
  GENERATING
  COMPLETED
  FAILED
}

enum ContentSource {
  TEMPLATE
  FREEFORM
  RECREATE
  WIZARD
  CAROUSEL
}

// ─── Credits ─────────────────────────────────────────

model CreditTransaction {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type        TransactionType
  amount      Int
  balance     Int
  description String
  contentId   String?
  stripePaymentId String?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([userId, createdAt])
}

enum TransactionType {
  PLAN_GRANT
  PURCHASE
  SPEND
  REFUND
  BONUS
}

// ─── Generation Jobs ─────────────────────────────────

model GenerationJob {
  id        String @id @default(cuid())
  userId    String
  contentId String?

  type   String
  status JobStatus @default(QUEUED)

  // Provider tracking
  provider      String
  providerJobId String?
  modelId       String

  // Input/output
  input  Json
  output Json?

  // Cost tracking
  estimatedCost Float?
  actualCost    Float?

  // Timing
  startedAt   DateTime?
  completedAt DateTime?
  error       String?

  createdAt DateTime @default(now())

  @@index([userId, status])
  @@index([providerJobId])
}

enum JobStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
}

// ─── Creator References ─────────────────────────────
// Per-creator reference library for consistent generations.
// NOT the same as ReferenceAccount/ReferencePost (admin Instagram collection).

model Reference {
  id                String    @id @default(cuid())
  creatorId         String?
  creator           Creator?  @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  userId            String
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  type              String    // "BACKGROUND" | "REFERENCE"
  name              String
  description       String    @default("")
  imageUrl          String    // S3 key
  tags              String[]
  starred           Boolean   @default(false)
  usageCount        Int       @default(0)
  lastUsedAt        DateTime?
  source            String    @default("UPLOAD")  // "UPLOAD" | "PUBLIC_SAVE" | "GENERATION_SAVE"
  sourcePublicRefId String?

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([userId])
  @@index([userId, starred])
  @@index([userId, lastUsedAt])
}

// ─── Reference Collection ────────────────────────────

model ReferenceAccount {
  id        String   @id @default(cuid())
  handle    String   @unique
  name      String?
  bio       String?
  followers Int?
  following Int?
  postCount Int?
  profilePicUrl String?

  // Instagram metadata
  isVerified    Boolean @default(false)
  isPrivate     Boolean @default(false)
  isBusiness    Boolean @default(false)
  categoryName  String?   // Instagram's category ("Digital creator", "Fitness Model")
  externalUrl   String?   // Link in bio

  // Our classification
  niche     String[]
  gender    String?
  vibe      String?
  quality   Int?
  notes     String?

  posts     ReferencePost[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ReferencePost {
  id        String   @id @default(cuid())
  accountId String
  account   ReferenceAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  shortcode     String
  postUrl       String
  s3Key         String
  mediaType     String  @default("image")   // "image" or "video"
  postType      String  @default("single")  // "single", "carousel", or "reel"
  carouselCount Int?                        // total slides if carousel
  width         Int?
  height        Int?
  caption       String?
  carouselIndex Int     @default(0)

  // Instagram metadata
  likeCount     Int?
  commentCount  Int?
  viewCount     Int?      // video views
  postedAt      DateTime? // when originally posted on IG
  location      String?   // tagged location
  altText       String?   // Instagram's auto-generated accessibility caption

  // Our classification
  pose          String?
  setting       String?
  outfit        String?
  lighting      String?
  composition   String?
  quality       Int?
  isGoodReference Boolean @default(true)

  // Triage tags (admin assigns these when reviewing collected posts)
  // Multiple tags allowed — a post can be both a good creator source AND background
  triageLabels  String[] // ["creator", "background", "reference", "custom", "skip"]
  triageStarred Boolean @default(false)

  publicReferences PublicReference[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([shortcode, carouselIndex])
  @@index([accountId])
  @@index([shortcode])
}

model PublicReference {
  id            String   @id @default(cuid())
  type          String   // "BACKGROUND" | "REFERENCE"
  name          String
  description   String   @default("")
  imageUrl      String   // S3 key
  tags          String[]
  category      String   // fitness, lifestyle, fashion, beauty, travel, general
  popularity    Int      @default(0)
  isActive      Boolean  @default(true)

  // Internal admin fields
  sourcePostId      String?
  sourcePost        ReferencePost? @relation(fields: [sourcePostId], references: [id])
  curatedBy         String?
  generationPrompt  String?
  generationModel   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([category])
  @@index([isActive])
}

// ─── Content Templates ──────────────────────────────
// Admin-published viral content templates that users can recreate with their creator.

model ContentTemplate {
  id              String   @id @default(cuid())
  type            String   // "IMAGE" | "VIDEO" | "CAROUSEL"
  name            String
  description     String   @default("")

  mediaUrl        String   // S3 key — the example output
  thumbnailUrl    String?  // S3 key — for grid display
  sourceVideoUrl  String?  // S3 key — original video for motion transfer

  category        String   // gym-fitness, city-lifestyle, fashion-beauty, travel, general
  trend           String   // mirror-selfie, grwm, city-walk, outfit-check, etc.
  tags            String[]

  generationConfig Json    // { prompt, aspectRatio, imageCount, videoSource, ... }

  isActive        Boolean  @default(true)
  popularity      Int      @default(0)
  createdBy       String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([category])
  @@index([trend])
  @@index([type])
  @@index([isActive, popularity])
}

// Admin-generated images — pipeline tracking + prompt journal
model AdminMedia {
  id        String   @id @default(cuid())
  s3Key     String   @unique
  source    String   // "seed-script", "admin-generate", "upload"
  mediaType String   @default("creator") // "creator", "background", "reference", "custom"
  starred   Boolean  @default(false)
  prompt    String?
  notes     String?
  sourceHandle String?

  // Pipeline
  pipelineStage String @default("inbox") // inbox, review, approved, published, rejected
  pipelineOrder Int    @default(0)

  // Prompt journal — what worked and why
  rating    Int?     // 1-5 stars, how good is this output
  feedback  String?  // "loved the lighting", "too AI", "great skin texture", etc.
  promptTags String[] // ["natural-hair", "warm-smile", "c-cup", "curly"] — what prompt elements worked

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([pipelineStage])
  @@index([mediaType])
  @@index([starred])
  @@index([rating])
}
